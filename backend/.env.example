# backend/.env dosyasi olustur (bu dosya .gitignore'da, commit'lenmez) ve
# asagidaki degiskeni kendi baglantinla doldur. database.py bu degisken
# olmadan baslamayi reddeder.

# Yerel gelistirme icin SQLite ornegi:
# DATABASE_URL_V2=sqlite:///./football_trivia.db

# Production (DigitalOcean Postgres) ornegi - sifreyi rotate ettikten sonra
# yeni degeri buraya yaz, ASLA git'e commit'leme:
# DATABASE_URL_V2=postgresql://doadmin:<YENI_SIFRE>@trivia-database-v2-do-user-18505351-0.i.db.ondigitalocean.com:25060/defaultdb?sslmode=require
DATABASE_URL_V2=
